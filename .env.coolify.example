# =============================================================================
# AxChat - variaveis de ambiente de PRODUCAO (Coolify)
# Copie estes valores para a tela de Environment Variables do Coolify.
# NAO commite o .env real com segredos.
# Legenda de servico: [api] = backend  [web] = frontend  [mcp] = MCP server
# =============================================================================

# --- URLs publicas -----------------------------------------------------------
# [api] dominio publico da API (sem /api/v1)
APP_URL=https://api.chat.seudominio.com
# [api] dominio publico do frontend (usado no CORS)
CORS_ORIGIN=https://chat.seudominio.com
# [web] dominio publico da API COM /api/v1 (embutido no build do Next)
NEXT_PUBLIC_API_URL=https://api.chat.seudominio.com/api/v1

# --- Runtime da API ----------------------------------------------------------
NODE_ENV=production          # [api]
PORT=3001                    # [api]
JWT_EXPIRATION=15m           # [api]
JWT_REFRESH_EXPIRATION=7d    # [api]
UPLOADS_DIR=/app/uploads     # [api] (volume Docker api_uploads)

# Segredos JWT gerados (troque se quiser, mas NAO use os de exemplo do repo)
JWT_SECRET=d6235a58b384f2b71972de2ec089ba91078be83f784c9b830d8a042560cf003812fe82717061a32a3b055096655b631e
JWT_REFRESH_SECRET=71dedfcb1af371261fcd675f2b96d01a2ae1a906445e9b2b4194ff68d9500f980f92f61d51f22c83b824e4cf62719f15

# --- PostgreSQL do Axdeal (banco logico axchat_db, MESMA rede Docker) --------
# host = nome do container Postgres do Axdeal: do8sok00k84gswgggccogoko
# [api]
DATABASE_URL=postgresql://PREENCHER_USUARIO:PREENCHER_SENHA@do8sok00k84gswgggccogoko:5432/axchat_db?schema=public

# --- Redis do Axdeal (MESMA rede Docker) -------------------------------------
# host = nome do container Redis do Axdeal: zhuzykenv2jheg9kqyyzx018
REDIS_HOST=zhuzykenv2jheg9kqyyzx018   # [api]
REDIS_PORT=6379                       # [api]
REDIS_PASSWORD=PREENCHER_SENHA_REDIS  # [api] (deixe vazio se o Redis nao exige senha)

# --- LLM (Fase 3) ------------------------------------------------------------
# DeepSeek = provider principal de TEXTO (compativel com SDK OpenAI)
DEEPSEEK_API_KEY=PREENCHER_CHAVE_DEEPSEEK         # [api]
DEEPSEEK_BASE_URL=https://api.deepseek.com        # [api]
# Anthropic/Claude = usado automaticamente para IMAGENS (DeepSeek nao tem visao)
ANTHROPIC_API_KEY=PREENCHER_CHAVE_ANTHROPIC       # [api]
# OpenAI = usado para transcricao de AUDIO (Whisper) e embeddings
OPENAI_API_KEY=PREENCHER_CHAVE_OPENAI             # [api]
# Modelo padrao dos agentes (novos seeds) e modelo de fallback para visao
AI_DEFAULT_MODEL_ID=deepseek-chat                 # [api]
AI_VISION_FALLBACK_MODEL_ID=claude-haiku-4-5      # [api]

# --- WhatsApp Oficial (Meta) -------------------------------------------------
# IMPORTANTE: as credenciais do WhatsApp NAO sao variaveis de ambiente.
# Elas sao configuradas POR CANAL no banco (channel.config), pela UI/API:
#   accessToken, phoneNumberId, businessAccountId, appSecret, verifyToken
# Webhook a cadastrar no Meta: {APP_URL}/api/v1/webhooks/WHATSAPP_OFFICIAL
# Veja a secao WhatsApp no DEPLOY.md.

# --- Integracoes opcionais (built-in tools) ----------------------------------
HOPPE_API_KEY=            # [api]
HOPPE_BASE_URL=           # [api]
MEMBERS_TRIVAPP_URL=      # [api]

# --- MCP server (baixa prioridade) -------------------------------------------
CHAT_BULLQ_BASE_URL=https://api.chat.seudominio.com   # [mcp]
CHAT_BULLQ_API_KEY=pk_PREENCHER_SE_FOR_USAR_MCP       # [mcp]
