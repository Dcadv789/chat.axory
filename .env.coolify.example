# Copy these variables into Coolify's environment screen.
# Do not commit the real .env with secrets.

# Public URLs
APP_URL=https://api.seudominio.com
CORS_ORIGIN=https://app.seudominio.com
NEXT_PUBLIC_API_URL=https://api.seudominio.com/api/v1

# API runtime
NODE_ENV=production
PORT=3001
JWT_SECRET=generate-a-long-random-secret
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=generate-another-long-random-secret
JWT_REFRESH_EXPIRATION=7d
UPLOADS_DIR=/app/uploads

# External PostgreSQL 17 Alpine
DATABASE_URL=postgresql://USER:PASSWORD@POSTGRES_HOST:5432/chat_bullq?schema=public

# External Redis
REDIS_HOST=REDIS_HOST
REDIS_PORT=6379
REDIS_PASSWORD=

# AI providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional integrations used by some built-in tools
HOPPE_API_KEY=
HOPPE_BASE_URL=
MEMBERS_TRIVAPP_URL=

# MCP service
CHAT_BULLQ_BASE_URL=https://api.seudominio.com
CHAT_BULLQ_API_KEY=pk_PASTE_YOUR_KEY_HERE

# MinIO is mentioned by the original env example, but current upload code uses local disk.
# Keep these only if a future S3/MinIO implementation is added.
MINIO_ENDPOINT=
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=chat-bullq
