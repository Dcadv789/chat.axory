{
  "name": "chat-axory",
  "private": true,
  "version": "1.0.0",
  "description": "AxChat monorepo: web, API and MCP services.",
  "scripts": {
    "install:all": "npm --prefix axchat-api install && npm --prefix axchat-web install && npm --prefix axchat-mcp install",
    "build": "npm --prefix axchat-api run build && npm --prefix axchat-web run build && npm --prefix axchat-mcp run build",
    "build:api": "npm --prefix axchat-api run build",
    "build:web": "npm --prefix axchat-web run build",
    "build:mcp": "npm --prefix axchat-mcp run build",
    "dev": "npm --prefix axchat-web run dev -- -p 3015",
    "dev:api": "npm --prefix axchat-api run start:dev",
    "dev:web": "npm --prefix axchat-web run dev -- -p 3015",
    "dev:mcp": "npm --prefix axchat-mcp run dev",
    "start:api": "npm --prefix axchat-api run start:local",
    "prisma:generate": "npm --prefix axchat-api run prisma:generate",
    "prisma:migrate": "npm --prefix axchat-api run prisma:migrate",
    "prisma:seed": "npm --prefix axchat-api run prisma:seed",
    "prisma:seed:agents": "npm --prefix axchat-api run prisma:seed:agents"
  }
}
