# AxChat - valores de desenvolvimento local.
# Requer PostgreSQL e Redis acessiveis da sua maquina.

APP_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://bravy:bravy123@localhost:5432/axchat_db?schema=public

JWT_SECRET=dev-only-change-me
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=dev-only-change-me-refresh
JWT_REFRESH_EXPIRATION=7d

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
UPLOADS_DIR=uploads

# LLM
DEEPSEEK_API_KEY=
