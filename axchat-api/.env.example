NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://bravy:bravy123@localhost:5432/chat_bullq

# JWT
JWT_SECRET=change-me-generate-with-node-e-require-crypto-randomBytes-64-toString-hex
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-generate-another-different-one
JWT_REFRESH_EXPIRATION=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# URLs públicas
APP_URL=http://localhost:3001
API_URL=http://localhost:3001
PUBLIC_API_URL=http://localhost:3001

# CORS
CORS_ORIGIN=http://localhost:3000

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=bravy
MINIO_SECRET_KEY=bravy123minio
MINIO_BUCKET=chat-bullq

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@bravy.com

# ─── IA / LLM ───
OPENAI_API_KEY=sk-proj-your-key-here
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_DEFAULT_MODEL_ID=
AI_VISION_FALLBACK_MODEL_ID=
# IDs de agentes com acesso a client-ops (csv). Default no código: agent_sofia_001
CLIENT_OPS_AGENT_IDS=agent_sofia_001
# Liga/desliga o worker de automações (kill switch). Default: ligado.
AUTOMATIONS_ENABLED=true

# ─── Integração de membros (Trivapp) ───
MEMBERS_TRIVAPP_URL=
MEMBERS_ADMIN_KEY=
MEMBERS_TENANT_BRAVY=

# ─── Hoppe (client-ops da Sofia) ───
HOPPE_BASE_URL=
HOPPE_API_KEY=

# ─── Google (Calendar/Drive — agendamento de reuniões) ───
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
DRIVE_MEET_FOLDER_ID=
SOFIA_CALENDAR_ID=
SOFIA_MEETING_INTERNAL_ATTENDEES=
